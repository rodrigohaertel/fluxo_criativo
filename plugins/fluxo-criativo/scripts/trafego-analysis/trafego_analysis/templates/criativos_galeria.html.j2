<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Galeria de Criativos — {{ produto }}</title>
<style>
  :root {
    --bg: #0f172a;
    --bg-card: #1e293b;
    --text: #e2e8f0;
    --text-dim: #94a3b8;
    --accent: #38bdf8;
    --accent-success: #22c55e;
    --accent-warn: #eab308;
    --accent-bad: #ef4444;
    --border: #334155;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    padding: 32px;
    line-height: 1.5;
  }
  header {
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  header h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
  header .meta { color: var(--text-dim); font-size: 14px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }
  .card {
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
  }
  .card .rank-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: rgba(15, 23, 42, 0.85);
    color: white;
    padding: 4px 10px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 14px;
    z-index: 2;
    border: 1px solid var(--border);
  }
  .card .class-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 4px 10px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 11px;
    z-index: 2;
  }
  .class-S { background: var(--accent-success); color: white; }
  .class-A { background: var(--accent); color: white; }
  .class-B { background: var(--accent-warn); color: black; }
  .class-C { background: #f97316; color: white; }
  .class-D { background: var(--accent-bad); color: white; }
  .card img {
    width: 100%;
    display: block;
    background: #0a0f1d;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
  .card .noimg {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: repeating-linear-gradient(45deg, #1a2332, #1a2332 10px, #202d3f 10px, #202d3f 20px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    font-size: 12px;
  }
  .card .info {
    padding: 14px;
  }
  .card .info .name {
    font-weight: 600;
    font-size: 13px;
    margin-bottom: 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card .info .campaign {
    color: var(--text-dim);
    font-size: 11px;
    margin-bottom: 10px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card .info .metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 12px;
    font-size: 11px;
  }
  .card .info .metrics .m-label { color: var(--text-dim); }
  .card .info .metrics .m-value { font-weight: 600; text-align: right; }
  .card .info .score-row {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
  }
  .card .info .score-row .label { color: var(--text-dim); }
  .card .info .score-row .value { font-weight: 700; font-size: 18px; }
  .palette {
    display: flex;
    gap: 3px;
    margin-top: 8px;
  }
  .palette .swatch {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border: 1px solid var(--border);
  }
  footer {
    margin-top: 48px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 12px;
    text-align: center;
  }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 100;
    align-items: center;
    justify-content: center;
    padding: 32px;
    flex-direction: column;
  }
  .lightbox.active { display: flex; }
  .lightbox img {
    max-width: min(90vw, 800px);
    max-height: 80vh;
    border-radius: 8px;
  }
  .lightbox .lb-info {
    margin-top: 16px;
    text-align: center;
    color: var(--text);
    max-width: 600px;
  }
  .lightbox .close-btn {
    position: absolute;
    top: 24px;
    right: 32px;
    background: none;
    border: none;
    color: var(--text);
    font-size: 32px;
    cursor: pointer;
    line-height: 1;
  }
</style>
</head>
<body>

<header>
  <h1>Galeria de Criativos — {{ produto }}</h1>
  <div class="meta">
    Período: <strong>{{ periodo.since.strftime('%d/%m/%Y') }}</strong> a <strong>{{ periodo.until.strftime('%d/%m/%Y') }}</strong>
    — {{ items | length }} criativos · gerado em {{ gerado_em }}
  </div>
</header>

<div class="grid">
  {% for item in items %}
  <div class="card" data-ad-id="{{ item.ad_id }}">
    <span class="rank-badge">#{{ item.rank }}</span>
    <span class="class-badge class-{{ item.ranking_quality }}">{{ item.ranking_quality }}</span>
    {% if item.img_b64 %}
    <img src="{{ item.img_b64 }}" alt="Criativo #{{ item.rank }}" loading="lazy">
    {% else %}
    <div class="noimg">sem thumb disponível</div>
    {% endif %}
    <div class="info">
      <div class="name" title="{{ item.ad_name }}">{{ item.ad_name }}</div>
      <div class="campaign" title="{{ item.campaign_name }}">{{ item.campaign_name }}</div>
      <div class="metrics">
        <span class="m-label">Hook</span><span class="m-value">{{ item.hook_rate | pct }}</span>
        <span class="m-label">Hold</span><span class="m-value">{{ item.hold_rate | pct }}</span>
        <span class="m-label">CTR</span><span class="m-value">{{ item.ctr | pct }}</span>
        <span class="m-label">CPA</span><span class="m-value">{{ item.cpa | brl }}</span>
        <span class="m-label">Gasto</span><span class="m-value">{{ item.spend | brl }}</span>
        {% if item.formato %}<span class="m-label">Formato</span><span class="m-value">{{ item.formato }}</span>{% endif %}
      </div>
      {% if item.paleta_hex %}
      <div class="palette">
        {% for cor in item.paleta_hex %}
        <div class="swatch" style="background: {{ cor }};" title="{{ cor }}"></div>
        {% endfor %}
      </div>
      {% endif %}
      <div class="score-row">
        <span class="label">Score</span>
        <span class="value">{{ '%.0f'|format(item.score) }}</span>
      </div>
    </div>
  </div>
  {% endfor %}
</div>

<div class="lightbox" id="lightbox">
  <button class="close-btn" onclick="closeLightbox()">&times;</button>
  <img id="lb-img" src="" alt="">
  <div class="lb-info" id="lb-info"></div>
</div>

<footer>
  Gerado por <strong>trafego</strong> — análise de tráfego pago Meta Ads
</footer>

<script>
  const cards = document.querySelectorAll('.card');
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbInfo = document.getElementById('lb-info');

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const img = card.querySelector('img');
      if (!img) return;
      lbImg.src = img.src;
      const name = card.querySelector('.name')?.textContent || '';
      const camp = card.querySelector('.campaign')?.textContent || '';
      lbInfo.innerHTML = '<div><strong>' + name + '</strong></div><div style="color:#94a3b8;font-size:13px">' + camp + '</div>';
      lb.classList.add('active');
    });
  });

  function closeLightbox() {
    lb.classList.remove('active');
    lbImg.src = '';
  }

  lb.addEventListener('click', (e) => {
    if (e.target === lb) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

</body>
</html>
