# ══════════════════════════════════════════
# Workshop Marketing IA — Chaves de API
# ══════════════════════════════════════════
#
# Copie este arquivo para .env e preencha suas chaves.
# O .env NUNCA sobe para o repositorio (protegido pelo .gitignore).
#
# IMPORTANTE: Todas as chaves sao OPCIONAIS.
# O toolkit funciona 100% sem nenhuma chave (nivel basico).
# As APIs sao melhorias progressivas para automatizar entregas.
#
# Niveis de uso:
#   Basico       — Nenhuma chave. Todos os entregaveis em arquivo local.
#   Intermediario — VERCEL_TOKEN + FREEPIK_API_KEY. Paginas online + imagens automaticas.
#   Avancado     — Todas as chaves. Automacao completa.

# ══════════════════════════════════════════
# VERCEL — Deploy automatico de paginas HTML
# ══════════════════════════════════════════
# Usado por: /pagina-de-vendas, agent construtor-de-paginas
# Obter em: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# ══════════════════════════════════════════
# FREEPIK — Geracao de imagens via IA
# ══════════════════════════════════════════
# Usado por: /criativo-estatico
# Obter em: https://www.freepik.com/api
FREEPIK_API_KEY=

# ══════════════════════════════════════════
# HEYGEN — Criacao de videos com avatar IA
# ══════════════════════════════════════════
# Usado por: /video-heygen (formato avatar)
# Obter em: https://app.heygen.com/settings
#
# COMO CONFIGURAR:
#   1. Acesse app.heygen.com > Settings > API > copie a API Key
#   2. (Opcional) Va em Avatars > selecione um > copie o ID
#   3. (Opcional) Va em Voices > selecione voz PT-BR > copie o ID
#
# Os campos AVATAR_ID e VOICE_ID sao opcionais.
# Se nao preencher, o /video-heygen lista as opcoes disponiveis para voce escolher.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ══════════════════════════════════════════
# META ADS — Gerenciamento de campanhas Facebook/Instagram
# ══════════════════════════════════════════
# Usado por: /copy-anuncio, agent criador-de-campanhas
# Obter em: https://developers.facebook.com
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ══════════════════════════════════════════
# FACEBOOK PIXEL — Rastreamento de conversoes
# ══════════════════════════════════════════
# Usado por: /pagina-pixel (instala Pixel em paginas HTML),
# /trafego-criar-campanha (valida Pixel antes de subir campanha Sales/Leads),
# agent construtor-de-paginas (insere Pixel automatico nas paginas)
# Obter em: Gerenciador de Eventos do Facebook
META_PIXEL_ID=

# Conversions API (opcional). Usado por /pagina-pixel quando o aluno opta
# por enviar eventos server-side. Token sensivel, nunca commitar.
META_PIXEL_CAPI_TOKEN=

# Codigo de teste do CAPI (opcional). Usado durante a validacao no
# Gerenciador de Eventos > Test Events.
META_PIXEL_TEST_EVENT_CODE=

# ══════════════════════════════════════════
# GOOGLE ADS — Gerenciamento de campanhas Google
# ══════════════════════════════════════════
# Usado por: /copy-anuncio, agent criador-de-campanhas
# Obter em: https://ads.google.com/intl/pt-BR/home/tools/manager-accounts/
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ══════════════════════════════════════════
# HOTMART — Links de checkout e consulta de vendas
# ══════════════════════════════════════════
# Usado por: /pagina-de-vendas (gera link de checkout), /low-ticket
# Obter em: https://app.hotmart.com/tools/api
HOTMART_TOKEN=
HOTMART_PRODUCT_ID=

# ══════════════════════════════════════════
# WHATSAPP BUSINESS — Mensagens automaticas
# ══════════════════════════════════════════
# Usado por: /sequencia-de-emails (envio de lembretes), /lancamento
# Obter em: https://developers.facebook.com (WhatsApp Cloud API)
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# ══════════════════════════════════════════
# RELATORIO DE ADS — Canal de notificacao diaria
# ══════════════════════════════════════════
# Usado por: /ads-relatorio, /enviar-relatorio-ads
# RELATORIO_CANAL: TELEGRAM (recomendado, gratis, sem risco de ban) ou WHATSAPP
RELATORIO_CANAL=

# Telegram — configurar com /ads-relatorio ou /configurar-telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Facebook Ads — token permanente tem prioridade sobre temporario
# Obter em: https://developers.facebook.com (use /gerar-token-permanente-facebook-ads)
FB_ACCESS_TOKEN_PERMANENTE=
FB_ACCESS_TOKEN_TEMPORARIO=
FB_AD_ACCOUNT_ID=

# WhatsApp via Z-API — so necessario se RELATORIO_CANAL=WHATSAPP
# Atencao: automacoes no WhatsApp tem risco de banimento do numero
# Use um numero secundario aquecido, nunca o numero principal da operacao
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
RELATORIO_WHATSAPP_NUMERO=

# ID da tarefa agendada no Claude (preenchido automaticamente pelo /ads-relatorio)
RELATORIO_CRON_ID=

# ══════════════════════════════════════════
# OPENROUTER — Varias ferramentas de IA (uma chave so)
# ══════════════════════════════════════════
# Obter em: https://openrouter.ai/settings/keys
# Cole a chave abaixo UMA vez e salve. Nunca envie o .env para ninguem nem suba no Git.
#
# Usado por:
#   /criativo-estatico — criativos de anuncio (veja OPENROUTER_IMAGE_MODEL abaixo)
#   scripts/generate-openrouter-nano-banana-images.py — imagens da pagina (Gemini Nano Banana)
#
OPENROUTER_API_KEY=
# Modelo para /criativo-estatico (deixe em branco para o padrao do comando)
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux-schnell
#
# Modelo para o script de imagens da pagina (Nano Banana = Gemini Flash Image no OpenRouter)
# Deixe em branco para usar o padrao do script.
OPENROUTER_MODEL=google/gemini-2.5-flash-image

# ══════════════════════════════════════════
# GEMINI (Google AI Studio) — Geracao direta de imagens
# ══════════════════════════════════════════
# Usado por: /gerar-furadeira (fluxo Rapido)
# Obter em: https://aistudio.google.com/app/apikey
#
# O fluxo Rapido chama direto a API do Google, sem passar pelo OpenRouter.
# Gratuito no tier free (com limites diarios). Para uso intensivo, ative
# billing no Google Cloud.
#
# O fluxo Refinado do /gerar-furadeira usa OPENROUTER_API_KEY (logo acima)
# com imagens de referencia em assets/furadeira-referencias/.
GEMINI_API_KEY=
